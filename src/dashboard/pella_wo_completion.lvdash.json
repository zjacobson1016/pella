{
  "datasets": [
    {
      "name": "wo_summary",
      "displayName": "Work Order Summary",
      "queryLines": [
        "SELECT COUNT(*) as total_work_orders, ",
        "COUNT(DISTINCT customer_id) as unique_customers, ",
        "COUNT(DISTINCT part_id) as unique_parts, ",
        "ROUND(AVG(total_amount), 2) as avg_quote_amount, ",
        "ROUND(AVG(days_to_completion), 1) as avg_days_to_complete ",
        "FROM mfg_mc_se_sa.pella.fact_work_order_completion ",
        "WHERE quote_id IS NOT NULL "
      ]
    },
    {
      "name": "wo_by_type",
      "displayName": "Work Orders by Type",
      "queryLines": [
        "SELECT wo_type, COUNT(*) as wo_count, ",
        "ROUND(AVG(total_amount), 2) as avg_amount, ",
        "ROUND(AVG(days_to_completion), 1) as avg_days ",
        "FROM mfg_mc_se_sa.pella.fact_work_order_completion ",
        "WHERE quote_id IS NOT NULL GROUP BY wo_type ORDER BY wo_count DESC "
      ]
    },
    {
      "name": "wo_by_priority",
      "displayName": "Work Orders by Priority",
      "queryLines": [
        "SELECT priority, COUNT(*) as wo_count, ",
        "ROUND(AVG(days_to_completion), 1) as avg_days ",
        "FROM mfg_mc_se_sa.pella.fact_work_order_completion ",
        "WHERE quote_id IS NOT NULL GROUP BY priority ORDER BY wo_count DESC "
      ]
    },
    {
      "name": "wo_monthly",
      "displayName": "Monthly Trend",
      "queryLines": [
        "SELECT DATE_TRUNC(\"MONTH\", created_date) as month, ",
        "COUNT(*) as wo_count, ",
        "ROUND(SUM(total_amount), 2) as total_value ",
        "FROM mfg_mc_se_sa.pella.fact_work_order_completion ",
        "WHERE quote_id IS NOT NULL ",
        "GROUP BY DATE_TRUNC(\"MONTH\", created_date) ORDER BY month "
      ]
    },
    {
      "name": "wo_by_tier",
      "displayName": "Work Orders by Customer Tier",
      "queryLines": [
        "SELECT customer_tier, COUNT(*) as wo_count, ",
        "ROUND(SUM(total_amount), 2) as total_value, ",
        "ROUND(AVG(days_to_completion), 1) as avg_days ",
        "FROM mfg_mc_se_sa.pella.fact_work_order_completion ",
        "WHERE quote_id IS NOT NULL GROUP BY customer_tier ORDER BY total_value DESC "
      ]
    },
    {
      "name": "wo_by_constraint",
      "displayName": "Work Orders by Availability Constraint",
      "queryLines": [
        "SELECT availability_constraint, COUNT(*) as wo_count, ",
        "ROUND(AVG(days_to_completion), 1) as avg_days ",
        "FROM mfg_mc_se_sa.pella.fact_work_order_completion ",
        "WHERE quote_id IS NOT NULL GROUP BY availability_constraint ORDER BY wo_count DESC "
      ]
    },
    {
      "name": "wo_detail",
      "displayName": "Work Order Detail",
      "queryLines": [
        "SELECT wo_type, priority, region, customer_tier, ",
        "COUNT(*) as wo_count, ",
        "ROUND(SUM(total_amount), 2) as total_value, ",
        "ROUND(AVG(days_to_completion), 1) as avg_days, ",
        "ROUND(AVG(parts_cost), 2) as avg_parts_cost, ",
        "ROUND(AVG(labor_cost), 2) as avg_labor_cost ",
        "FROM mfg_mc_se_sa.pella.fact_work_order_completion ",
        "WHERE quote_id IS NOT NULL ",
        "GROUP BY wo_type, priority, region, customer_tier ",
        "ORDER BY total_value DESC LIMIT 50 "
      ]
    },
    {
      "name": "df_summary",
      "displayName": "Demand Fulfillment Summary",
      "queryLines": [
        "SELECT COUNT(DISTINCT po_id) as total_pos, ",
        "COUNT(DISTINCT signal_id) as total_signals, ",
        "COUNT(DISTINCT part_id) as unique_parts, ",
        "ROUND(SUM(po_total_value), 2) as total_po_value, ",
        "ROUND(AVG(receipt_variance_days), 1) as avg_delivery_variance, ",
        "ROUND(AVG(days_to_payment), 1) as avg_days_to_payment ",
        "FROM mfg_mc_se_sa.pella.fact_demand_fulfillment "
      ]
    },
    {
      "name": "df_by_status",
      "displayName": "POs by Status",
      "queryLines": [
        "SELECT po_status, COUNT(DISTINCT po_id) as po_count, ",
        "ROUND(SUM(po_total_value), 2) as total_value ",
        "FROM mfg_mc_se_sa.pella.fact_demand_fulfillment ",
        "WHERE po_id IS NOT NULL ",
        "GROUP BY po_status ORDER BY po_count DESC "
      ]
    },
    {
      "name": "df_by_signal_type",
      "displayName": "Forecast by Signal Type",
      "queryLines": [
        "SELECT signal_type, ",
        "COUNT(DISTINCT signal_id) as signal_count, ",
        "ROUND(AVG(forecast_variance), 1) as avg_variance ",
        "FROM mfg_mc_se_sa.pella.fact_demand_fulfillment ",
        "WHERE signal_id IS NOT NULL ",
        "GROUP BY signal_type ORDER BY signal_count DESC "
      ]
    },
    {
      "name": "df_monthly",
      "displayName": "Monthly PO Trend",
      "queryLines": [
        "SELECT DATE_TRUNC('MONTH', po_date) as month, ",
        "COUNT(DISTINCT po_id) as po_count, ",
        "ROUND(SUM(po_total_value), 2) as total_value ",
        "FROM mfg_mc_se_sa.pella.fact_demand_fulfillment ",
        "WHERE po_id IS NOT NULL ",
        "GROUP BY DATE_TRUNC('MONTH', po_date) ORDER BY month "
      ]
    },
    {
      "name": "df_by_category",
      "displayName": "Demand by Part Category",
      "queryLines": [
        "SELECT category, ",
        "COUNT(DISTINCT po_id) as po_count, ",
        "ROUND(SUM(po_total_value), 2) as total_value, ",
        "ROUND(AVG(receipt_variance_days), 1) as avg_delivery_variance ",
        "FROM mfg_mc_se_sa.pella.fact_demand_fulfillment ",
        "WHERE po_id IS NOT NULL AND category IS NOT NULL ",
        "GROUP BY category ORDER BY total_value DESC "
      ]
    },
    {
      "name": "df_payment",
      "displayName": "Payment Status",
      "queryLines": [
        "SELECT payment_status, ",
        "COUNT(DISTINCT invoice_id) as invoice_count, ",
        "ROUND(SUM(invoice_amount), 2) as total_amount ",
        "FROM mfg_mc_se_sa.pella.fact_demand_fulfillment ",
        "WHERE invoice_id IS NOT NULL ",
        "GROUP BY payment_status ORDER BY invoice_count DESC "
      ]
    },
    {
      "name": "df_detail",
      "displayName": "Demand Fulfillment Detail",
      "queryLines": [
        "SELECT category, signal_type, po_status, demand_region, ",
        "COUNT(DISTINCT po_id) as po_count, ",
        "ROUND(SUM(po_total_value), 2) as total_po_value, ",
        "ROUND(AVG(forecast_variance), 1) as avg_forecast_variance, ",
        "ROUND(AVG(receipt_variance_days), 1) as avg_delivery_variance, ",
        "ROUND(SUM(invoice_amount), 2) as total_invoiced ",
        "FROM mfg_mc_se_sa.pella.fact_demand_fulfillment ",
        "WHERE po_id IS NOT NULL ",
        "GROUP BY category, signal_type, po_status, demand_region ",
        "ORDER BY total_po_value DESC LIMIT 50 "
      ]
    }
  ],
